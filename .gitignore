# 1. 모든 것을 무시
/*

# 2. .gitignore 자기 자신은 예외 (이게 있어야 법전이 먹힙니다)
!.gitignore

# 3. [핵심] 성문을 열고, 그 안의 모든 사람을 허용한다
!/gray_gamer_ambience/
!/gray_gamer_ambience/**

# 4. [핵심] 데이터 창고 개방
!/gray_gamer_ambience/novel_memory/
!/gray_gamer_ambience/novel_memory/**

# 5. 관제탑 개방
!/.github/
!/.github/workflows/
!/.github/workflows/*.yml

# 6. 쓰레기들만 정밀 타격 (어디 있든 무조건 차단)
**/.DS_Store
**/__pycache__/
**/*.pyc
config.json